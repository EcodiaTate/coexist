# ================================================================
# Co-Exist Environment Configuration
# ================================================================
# Copy this file to .env.local for development
# Copy to .env.production for production builds
#
# NEVER commit .env.local or .env.production to git
# ================================================================

# ---- Supabase ----
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ---- Stripe ----
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here

# ---- Analytics (provider: "posthog" | "plausible" | "mixpanel" | "none") ----
VITE_ANALYTICS_PROVIDER=none
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com

# ---- Sentry (error reporting) ----
VITE_SENTRY_DSN=
VITE_APP_VERSION=1.0.0

# ================================================================
# Supabase Edge Function Secrets (set via Supabase Dashboard)
# These are NOT prefixed with VITE_ - they are server-only
# ================================================================
#
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
#
# SENDGRID_API_KEY=SG....
# SENDGRID_FROM_EMAIL=hello@coexistaus.org
# SENDGRID_FROM_NAME=Co-Exist
# SENDGRID_TPL_WELCOME=d-...
# SENDGRID_TPL_EVENT_CONFIRMATION=d-...
# SENDGRID_TPL_EVENT_REMINDER=d-...
# SENDGRID_TPL_EVENT_CANCELLED=d-...
# SENDGRID_TPL_EVENT_INVITE=d-...
# SENDGRID_TPL_WAITLIST_PROMOTED=d-...
# SENDGRID_TPL_PASSWORD_RESET=d-...
# SENDGRID_TPL_DONATION_RECEIPT=d-...
# SENDGRID_TPL_ORDER_CONFIRMATION=d-...
# SENDGRID_TPL_ORDER_SHIPPED=d-...
# SENDGRID_TPL_DATA_EXPORT=d-...
# SENDGRID_TPL_NEWSLETTER=d-...
# SENDGRID_TPL_CHALLENGE=d-...
# SENDGRID_TPL_IMPACT_RECAP=d-...
# SENDGRID_TPL_ANNOUNCEMENT_DIGEST=d-...
#
# FCM_PROJECT_ID=your-firebase-project-id
# FCM_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
